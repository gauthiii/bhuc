# BHUC frontend environment (copy to .env.local and fill in your own values)
# When true (default), screens render from in-memory mock fixtures — no backend needed.
VITE_USE_MOCK=true
# FastAPI backend base (used when VITE_USE_MOCK=false). Dev proxy also reads this.
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_API_BASE=/api/x_bhuc
# AWS Cognito (Cognito-ready; only used when real auth is enabled).
# Fill these with YOUR pool values — do not commit real values.
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
