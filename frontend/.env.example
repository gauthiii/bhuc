# BHUC frontend environment (copy to .env.local)
#
# NOTE: the frontend does NOT talk to AWS Cognito directly and needs NO Cognito/AWS
# credentials. Authentication goes: frontend -> backend (/api/aws/*) -> Cognito.
# All Cognito/AWS secrets live in server/.env only.

# When true (default), screens render from in-memory mock fixtures — no backend needed.
VITE_USE_MOCK=true

# Per-endpoint override: route ONLY the front-door chat to the live backend (the
# Front-Door Security Agent is built & verified over A2A) while the rest stays on
# mock until those routes exist. Set false to keep the front-door on mock too.
VITE_FRONTDOOR_LIVE=true

# FastAPI backend. Dev proxy forwards /api to this target.
VITE_API_PROXY_TARGET=http://localhost:8000
# Base path for BHUC data/agent endpoints.
VITE_API_BASE=/api/x_bhuc
# Base path for the Cognito auth router (defaults to /api if unset).
VITE_AWS_API_BASE=/api
