# BHUC backend environment (copy to server/.env)
# --- AWS Cognito (email/password + TOTP MFA) ---
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# --- AWS credentials for boto3 (cognito-idp admin calls) ---
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
# --- CORS ---
CORS_ORIGINS=http://localhost:5173
# --- ServiceNow (optional; A2A/CRUD layer, later) ---
SNOW_INSTANCE=ven04690.service-now.com
SNOW_USERNAME=
SNOW_PASSWORD=
SNOW_A2A_CLIENT_ID=
SNOW_A2A_CLIENT_SECRET=
